{
  "expo": {
    "name": "ImmOver Pro",
    "slug": "immover-pro",
    "version": "2.1.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mpyatech.immoverpro",
      "buildNumber": "32",
      "infoPlist": {
        "NSCameraUsageDescription": "Autoriser l'application à accéder à votre camera pour prendre des photos de votre profil et de vos biens immobiliers"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#D14D31",
      "translucent": false
    },
    "android": {
      "package": "com.mpyatech.immoverpro",
      "versionCode": 32,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser l'application à accéder à votre galerie  pour prendre des photos de votre profil et de vos biens immobiliers",
          "cameraPermission": "Autoriser l'application à accéder à votre camera pour prendre des photos de votre profil et de vos biens immobiliers"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true,
            "kotlinVersion": "2.1.20",
            "kotlinGradlePluginVersion": "2.1.20",
            "kspVersion": "2.1.20-1.0.29"
          },
          "ios": {
            "deploymentTarget": "15.1",
            "NSCameraUsageDescription": "Autoriser l'application à accéder à votre camera pour prendre des photos de votre profil et de vos biens immobiliers",
            "NSPhotoLibraryUsageDescription": "Autoriser l'application à accéder à votre camera pour prendre des photos de votre profil et de vos biens immobiliers"
          }
        }
      ],
      "expo-video"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "9b025515-8eb5-4f06-9f59-e52804014371"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9b025515-8eb5-4f06-9f59-e52804014371"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
